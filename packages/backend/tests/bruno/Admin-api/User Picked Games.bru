meta {
  name: User Picked Games
  type: http
  seq: 8
}

post {
  url: http://{{host}}/api/user/picks
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "year": "2025",
    "week": "1",
    "seasonType": "regular",
    "games": [
      {
        "game": {{game1}},
        "pick": "home_team"
      },
      {
        "game":{{game2}},
        "pick": "home_team"
      },
      {
        "game": {{game3}},
        "pick": "away_team"
      },
      {
        "game": {{game4}},
        "pick": "home_team"
      },
      {
        "game": {{game5}},
        "pick": "home_team"
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
