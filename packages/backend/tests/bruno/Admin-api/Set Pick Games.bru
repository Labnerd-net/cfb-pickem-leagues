meta {
  name: Set Pick Games
  type: http
  seq: 6
}

post {
  url: http://{{host}}/api/admin/setpicks
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "year": "2025",
    "week": "1",
    "seasonType": "regular",
    "games": [ {{game1}},{{game2}},{{game3}},{{game4}},{{game5}} ]
  }
}

assert {
  res.body.id: isNumber
  res.body.email: eq brian@email.com
  res.body.isAdmin: isBoolean
  res.status: eq 200
}

settings {
  encodeUrl: true
  timeout: 0
}
