meta {
  name: Delete User no token
  type: http
  seq: 10
}

delete {
  url: http://{{host}}/api/auth/deleteUser
  body: none
  auth: inherit
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.status: eq 401
  res.body: eq "Unauthorized"
}

settings {
  encodeUrl: true
  timeout: 0
}
