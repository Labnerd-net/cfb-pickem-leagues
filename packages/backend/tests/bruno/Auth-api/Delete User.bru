meta {
  name: Delete User
  type: http
  seq: 11
}

delete {
  url: http://{{host}}/api/auth/deleteUser
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.status: eq 200
  res.body.data.status: eq "deleted"
}

settings {
  encodeUrl: true
  timeout: 0
}
