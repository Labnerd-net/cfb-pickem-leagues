meta {
  name: Register User duplicate
  type: http
  seq: 4
}

post {
  url: http://{{host}}/api/auth/register
  body: json
  auth: inherit
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.body.error: eq "User already exists"
  res.status: eq 409
}

settings {
  encodeUrl: true
  timeout: 0
}
