meta {
  name: User Info wrong token
  type: http
  seq: 5
}

get {
  url: http://{{host}}/api/auth/{{id}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer 1
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.status: eq 401
  res.body.error: eq "Invalid or expired token"
}

settings {
  encodeUrl: true
  timeout: 0
}
