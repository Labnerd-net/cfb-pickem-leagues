meta {
  name: Login User
  type: http
  seq: 2
}

post {
  url: http://{{host}}/api/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.body.data.token: isString
  res.body.data.id: isNumber
  res.status: eq 200
}

script:post-response {
  bru.setVar("token", res.body.data.token);
  bru.setVar("id", res.body.data.id);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
