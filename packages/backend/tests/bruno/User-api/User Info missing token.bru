meta {
  name: User Info missing token
  type: http
  seq: 4
}

get {
  url: http://{{host}}/api/auth/{{id}}
  body: none
  auth: inherit
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.status: eq 401
  res.body.error: eq "Missing token"
}

settings {
  encodeUrl: true
  timeout: 0
}
