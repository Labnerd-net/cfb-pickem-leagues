meta {
  name: User Info
  type: http
  seq: 3
}

get {
  url: http://{{host}}/api/user/profile
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.body.data.id: isNumber
  res.body.data.email: eq brian@email.com
  res.status: eq 200
}

settings {
  encodeUrl: true
  timeout: 0
}
