meta {
  name: Register User
  type: http
  seq: 1
}

post {
  url: http://{{host}}/api/auth/register
  body: json
  auth: inherit
}

body:json {
  {
    "email": "brian@email.com",
    "password": "monkey"
  }
}

assert {
  res.body.token: isString
  res.status: eq 200
}

settings {
  encodeUrl: true
  timeout: 0
}
