meta {
  name: Get Games
  type: http
  seq: 6
}

post {
  url: http://{{host}}/api/admin/getgames
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "year": "2025",
    "week": "1",
    "seasonType": "regular"
  }
}

assert {
  res.body.error: eq Forbidden
  res.status: eq 403
}

settings {
  encodeUrl: true
  timeout: 0
}
