# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cfb-pickem

# Server Configuration
SERVER_PORT=3000
CLIENT_URL=http://localhost:5173,http://localhost:4173

# JWT Authentication (REQUIRED - must set unique secret in production)
# WARNING: Replace this with a secure random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7
JWT_SALT_ROUNDS=10

# External Data Source
# Options: ncaa, cfbd, sdv
DATA_SOURCE=ncaa

# CFBD API Key (required only if DATA_SOURCE=cfbd)
# Get your key at: https://collegefootballdata.com/
CFBD_API_KEY=
