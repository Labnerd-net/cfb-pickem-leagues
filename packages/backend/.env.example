# Database Configuration
# Neon connection strings
# DEV_DB is used when NODE_ENV != production
# PROD_DB is used when NODE_ENV=production
DEV_DB=
PROD_DB=

# Server Configuration
SERVER_PORT=3000
CLIENT_URL=http://localhost:5173,http://localhost:4173

# JWT Authentication (REQUIRED - must set unique secret in production)
# WARNING: Replace this with a secure random string in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# CFBD API Key (required)
# Get your key at: https://collegefootballdata.com/
CFBD_API_KEY=

# Logging
# Options: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# Pick Deadline
# Set to 'true' to bypass the pick deadline enforcement (useful for off-season testing)
PICKS_IGNORE_DEADLINE=false

# Notifications — Email (Resend)
# Leave blank to disable email notifications entirely
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
# Set to 'true' in dev to skip actual email sends (logs instead)
SKIP_EMAIL_SEND=false

# Notifications — Broadcast channels (admin-configured; leave blank to disable)
# ntfy: full topic URL, e.g. https://ntfy.sh/cfb-pickem or https://:TOKEN@ntfy.example.com/my-topic
NTFY_TOPIC_URL=
# Telegram: bot token from BotFather + the group/channel chat ID to post to
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Public invite link shown to users in Settings (e.g. https://t.me/yourchannel)
TELEGRAM_INVITE_URL=
# Discord: webhook URL for a channel
DISCORD_WEBHOOK_URL=
# Public invite link shown to users in Settings (e.g. https://discord.gg/abc123)
DISCORD_INVITE_URL=
