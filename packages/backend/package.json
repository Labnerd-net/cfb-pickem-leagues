{
  "name": "cfb-pickem-api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/backend/src/index.js",
    "start:prod": "pnpm migrate:prod && node dist/backend/src/index.js",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write ./src",
    "generate": "npx drizzle-kit generate",
    "migrate": "npx drizzle-kit migrate",
    "migrate:prod": "NODE_ENV=production node dist/backend/src/scripts/migrate-prod.js",
    "studio": "npx drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.996.0",
    "@hono/node-server": "^1.19.9",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.0",
    "bcryptjs": "^3.0.3",
    "cfbd": "^5.13.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.7",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.17.2",
    "pino": "^9.6.0",
    "sportsdataverse": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
