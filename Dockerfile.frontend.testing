# Testing frontend image — identical to Dockerfile.frontend but with VITE_LOG_LEVEL=debug baked in.
# Build:
#   docker build -f Dockerfile.frontend.testing --build-arg VITE_API_URL=https://api.yourdomain.com -t cfb-frontend-testing .

FROM node:20-alpine AS base

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace files
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./

# Copy all package manifests
COPY packages/frontend/package.json packages/frontend/
COPY packages/shared/package.json packages/shared/

# ================================
# Dependencies stage
# ================================
FROM base AS deps
RUN pnpm install --frozen-lockfile

# ================================
# Build stage
# ================================
FROM base AS build

# VITE_API_URL must be set at build time (Vite bakes env vars into the bundle)
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Bake debug logging into this testing image
ENV VITE_LOG_LEVEL=debug

# Copy dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/frontend/node_modules ./packages/frontend/node_modules

# Copy source
COPY packages/frontend ./packages/frontend
COPY packages/shared ./packages/shared

WORKDIR /app/packages/frontend
RUN pnpm build

# ================================
# Production stage (nginx)
# ================================
FROM nginx:alpine AS production

# Copy nginx config with React Router fallback
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built static files
COPY --from=build /app/packages/frontend/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
